{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",

  "redirects": [
    { "source": "/movie/:slug", "destination": "/phim/:slug", "permanent": true }
  ],

  "rewrites": [
    { "source": "/sitemap-movies.xml", "destination": "/api/sitemap-dynamic" },
    { "source": "/sitemap-categories.xml", "destination": "/api/sitemap-categories" },
    { "source": "/sitemap-images.xml", "destination": "/api/sitemap-images" },
    { "source": "/rss.xml", "destination": "/api/rss" },
    { "source": "/api/telegram-notify", "destination": "/api/telegram-notify" },

    {
      "source": "/phim/:slug",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|sogou|exabot|ia_archiver|msnbot|ahrefsbot|semrushbot|dotbot|seznambot).*" }],
      "destination": "/api/seo-prerender"
    },
    {
      "source": "/type/:type",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|applebot|sogou|exabot|ia_archiver|msnbot|ahrefsbot|semrushbot|dotbot|seznambot).*" }],
      "destination": "/api/seo-prerender"
    },

    { "source": "/((?!api/|assets/|.*\\.(?:xml|txt|ico|png|jpg|webp|svg|json)$).*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
