# chat gpt_API_KEY: Required for chat gpt API calls.
# chat gpt automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the chat gpt UI.
chat gpt_API_KEY="MY_chat gpt_API_KEY"

# APP_URL: The URL where this applet is hosted.
# chat gpt automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
